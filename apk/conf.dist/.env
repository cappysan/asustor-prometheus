LISTEN_ADDRESS="0.0.0.0:9090"
CONFIG_FILE=/share/Configuration/prometheus/prometheus.yml
WEBCONFIG_FILE=/share/Configuration/prometheus/web.yml
CMDLINE_APPEND=""

# Use /usr/local/AppCentral/cappysan-prometheus/prometheus-data if you
# wish to save it on the same location than the application.
# Asustor upgrades of an app will delete the folder then recreate it, so
# don't use a subdirectory of cappysan-prometheus if you wish to keep your
# data
#
# STORAGE_TSDB_PATH=/usr/local/AppCentral/cappysan-prometheus-data
#
# Thus, use /share/Configuration/prometheus/data to keep it persistent
#
STORAGE_TSDB_PATH=/share/Configuration/prometheus/data
