{
  "general": {
    "architecture": "x86-64",
    "conflicts": [],
    "depends": [
      "python3(>=3.10.0)"
    ],
    "email": "julien@cappysan.dev",
    "firmware": "5.0.0",
    "maintainer": "Cappysan",
    "name": "Prometheus",
    "package": "cappysan-prometheus",
    "version": "3.12.0-r89",
    "developer": "Cappysan",
    "website": "https://gitlab.com/cappysan/asustor/prometheus"
  },
  "adm-desktop": {
    "app": {
      "type": "internal",
      "js": [
        "prometheus.js"
      ],
      "css": [
        "prometheus.css"
      ],
      "module": "AS.ARC.apps.prometheus.main",
      "langTag": "PROMETHEUS"
    },
    "privilege": {
      "accessible": "administrators",
      "customizable": false
    }
  },
  "register": {
    "share-folder": [
      {
        "name": "Configuration",
        "description": "Application configuration"
      }
    ],
    "boot-priority": {
      "x-comment": "docker-ce start order is 65",
      "start-order": 70,
      "stop-order": 30
    },
    "port": [
      9090
    ],
    "symbolic-link": {
      "/bin": [
        "promtool"
      ]
    }
  }
}
